# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url_here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"


# ─── OpenRouter (AI Question Generation & Feedback) ─────────
OPENROUTER_API_KEY="your_openrouter_api_key_here"
# Model used for both question generation and feedback (required — code throws if unset).
OPENROUTER_MODEL="nvidia/nemotron-3-super-120b-a12b:free"

# ─── Host URL (Interview Link Base URL) ─────────────────────
NEXT_PUBLIC_HOST_URL="http://localhost:3000/interview"

# ─── Vapi AI (Voice Agent) ──────────────────────────────────
NEXT_PUBLIC_VAPI_PUBLIC_KEY="your_vapi_public_key_here"

# ─── Supabase Service Role (server-side writes) ─────────────
# Required for API routes that write to interview-feedback without user auth.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# ─── Vapi Webhook (server-side feedback recovery) ───────────
# Public URL that Vapi sends end-of-call-report events to.
# Set this to enable the webhook fallback path (e.g. https://yourdomain.com/api/vapi/webhook).
# When unset, only the frontend-triggered feedback path is active.
NEXT_PUBLIC_VAPI_SERVER_URL=""
# Shared secret for authenticating Vapi webhook requests. Required when the webhook is enabled.
VAPI_WEBHOOK_SECRET=""

# ─── WebSocket Server ───────────────────────────────────────
# HTTP base URL of the collaborative editor server (used for REST code fetch).
NEXT_PUBLIC_WS_SERVER_URL="http://localhost:8080"
# WebSocket (ws:// or wss://) URL the editor connects to. Falls back to ws://localhost:8080 if unset.
NEXT_PUBLIC_WS_URL="ws://localhost:8080"

# ─── Upstash Redis (rate limiting for /api/ai-feedback) ─────
# Required: lib/rate-limit.js calls Redis.fromEnv() at import, which throws if these are missing.
UPSTASH_REDIS_REST_URL="your_upstash_redis_rest_url_here"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token_here"
