# Port (Railway/Render inject this automatically)
PORT=8080

# Comma-separated frontend origins allowed to connect
CLIENT_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Redis (Upstash, Railway Redis, etc.)
REDIS_URL=redis://default:password@host:6379

# Supabase — same project as your Next.js app
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: explicit instance id (auto-generated if omitted)
# INSTANCE_ID=ws-1
